{
  "name": "@pathetic_geek/blog",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "prisma generate && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "prettier --check  \"**/*.{js,jsx,ts,tsx,md,mdx,astro}\" && eslint \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "lint:fix": "prettier --write  \"**/*.{js,jsx,ts,tsx,md,mdx,astro}\" && eslint --fix \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "prepare": "pnpm prisma generate && husky",
    "bookmark-sync": "node --env-file=.env ./bookmark_sync.js",
    "clean": "rm -r node_modules .astro dist .vercel"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,md,mdx,astro}": [
      "pnpm lint"
    ]
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^9.0.2",
    "@types/node": "^20.19.26",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/sharp": "0.30.4",
    "@typescript-eslint/parser": "^5.62.0",
    "astro": "^5.16.5",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^0.23.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.7.4",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "prisma": "^4.16.2",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.14",
    "@google/genai": "^0.9.0",
    "@octokit/rest": "^19.0.13",
    "@prisma/client": "^4.16.2",
    "@upstash/vector": "^1.2.2",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^1.2.1",
    "jsdom": "^24.1.3",
    "ms": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "satori": "^0.10.14",
    "satori-html": "^0.3.2",
    "sharp": "0.30.4",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@8.12.1",
  "engines": {
    "node": "^24.12.0"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "linux",
        "current"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  }
}
